# ============================================================================
# Work Permit Intelligence Agent — environment
# Copy to `.env.local` for development.  The ONLY paid dependency is Gemini.
# ============================================================================

# Google Gemini API key — the single paid dependency.
# Get a free key: https://aistudio.google.com/app/apikey
# If left empty, the app still runs end-to-end using the deterministic
# offline pipeline (real OCR + heuristic analysis), with a visible notice.
GOOGLE_API_KEY=

# Optional model overrides.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Tesseract OCR languages (download on first use). e.g. "eng", "eng+deu".
OCR_LANGS=eng+deu

# Force the deterministic offline pipeline even if a key is present (no Gemini calls).
FORCE_MOCK=

# Frontend-only: force the shell's mock streaming (skips the backend entirely).
NEXT_PUBLIC_USE_MOCK=

# Optional: point the frontend at a different backend (defaults to same-origin /api/run).
# NEXT_PUBLIC_API_URL=
