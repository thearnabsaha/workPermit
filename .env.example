# ============================================================================
# Work Permit Intelligence Agent - FRONTEND (Next.js) environment
# Copy to `.env.local`.  The Python backend has its own env (see backend/.env.example).
# ============================================================================

# Where the frontend sends documents. Point this at the Python FastAPI backend.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/run

# Force the shell's built-in mock streaming (skips the backend entirely).
# Leave empty for normal operation.
NEXT_PUBLIC_USE_MOCK=
