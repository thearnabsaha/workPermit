# ============================================================================
# Work Permit Intelligence Agent - Python backend environment
# Copy to `.env` (in the backend/ folder).  The ONLY paid dependency is Gemini.
# ============================================================================

# Google Gemini API key - the single paid dependency.
# Get a free key: https://aistudio.google.com/app/apikey
# If left empty, the backend still runs end-to-end using the deterministic
# offline pipeline (PDF text + heuristics). Image OCR needs the key (Gemini vision).
GOOGLE_API_KEY=

# Optional model overrides.
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Force the deterministic offline pipeline even if a key is present.
FORCE_MOCK=

# Allowed CORS origin for the Next.js frontend.
FRONTEND_ORIGIN=http://localhost:3000
